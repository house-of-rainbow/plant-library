# Frontend environment configuration (local dev).
# Base URL for API calls. Leave empty to use the Vite dev proxy (/api -> backend).
VITE_API_BASE_URL=

# EntraID (MSAL) — used only when auth is enabled in the app.
VITE_AUTH_DISABLED=true
VITE_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_ENTRA_TENANT_ID=common
VITE_ENTRA_API_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user
