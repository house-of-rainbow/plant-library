# Auth — disabled for local dev.
AUTH_DISABLED=true
ENTRA_TENANT_ID=common
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_API_AUDIENCE=00000000-0000-0000-0000-000000000000

